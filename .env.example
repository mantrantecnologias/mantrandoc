# ==============================================================================
# Template de variáveis de ambiente do Docs (React + Vite) — deploy ISOLADO.
# Copie para `apps/docs/.env` e preencha os valores. O `.env` real é ignorado pelo git.
#
# Em dev no monorepo, este arquivo (se presente) tem precedência sobre o `.env` da
# raiz; a raiz preenche apenas as lacunas. Em deploy isolado do docs, este é a única
# fonte (ou variáveis de ambiente reais do host).
# ==============================================================================

# ------------------------------------------------------------------------------
# Variáveis do docs
#   DOCS_PORT          → porta do dev server do Vite
#   DOCS_API_URL       → alvo do proxy /api (URL da API, usado só no login de suporte.mantran)
#   DOCS_API_BASE_URL  → opcional. Preencha só em produção, quando a API fica em domínio
#                        diferente do docs (ex.: subdomínios). Vazio = chamadas relativas
#                        (proxy do Vite em dev, mesma origem em prod).
# ------------------------------------------------------------------------------
DOCS_PORT=5542
DOCS_API_URL=https://localhost:7740
DOCS_API_BASE_URL=
